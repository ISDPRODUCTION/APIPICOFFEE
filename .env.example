APP_NAME="Apipi Coffee"
APP_ENV=production
# Wajib di Railway Variables (php artisan key:generate --show)
APP_KEY=
APP_DEBUG=false
APP_URL=https://apipicoffee-production.up.railway.app

LOG_CHANNEL=stderr
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# Railway MySQL — isi dari variabel yang disediakan Railway
DB_CONNECTION=mysql
DB_HOST=
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=s3
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

# ── Cloudflare R2 Storage ──────────────────────────────────────────────────────
# Access Key & Secret: buat di Cloudflare R2 → Manage API Tokens
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Region untuk R2 selalu "auto"
AWS_DEFAULT_REGION=auto
# Nama bucket R2 kamu
AWS_BUCKET=
# API endpoint (upload dari server): https://<ACCOUNT_ID>.r2.cloudflarestorage.com
AWS_ENDPOINT=
# URL publik untuk browser (WAJIB): https://pub-<id>.r2.dev  ATAU custom domain
# Bukan AWS_ENDPOINT — salah setting menyebabkan gambar timeout / SSL error di browser
AWS_URL=
# R2 wajib true (path-style endpoint)
AWS_USE_PATH_STYLE_ENDPOINT=true
# true = gambar lewat /media/... (domain app), hindari error SSL pub-*.r2.dev di browser
STORAGE_PROXY_MEDIA=true
